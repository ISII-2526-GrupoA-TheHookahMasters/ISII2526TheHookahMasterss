  "components": {
    "schemas": {
      "AlquilarItemDTO": {
        "required": [
          "cantidad",
          "material",
          "nombreHerramienta",
          "precio"
        ],
        "type": "object",
        "properties": {
          "herramientaId": {
            "type": "integer",
            "format": "int32"
          },
          "nombreHerramienta": {
            "minLength": 1,
            "type": "string"
          },
          "material": {
            "minLength": 1,
            "type": "string"
          },
          "cantidad": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "precio": {
            "type": "number",
            "format": "currency"
          }
        },
        "additionalProperties": false
      },
      "AlquilerDetailDTO": {
        "required": [
          "apellidosCliente",
          "direccionEnvio",
          "fechaAlquiler",
          "nombreCliente",
          "periodo",
          "precioTotal"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "nombreCliente": {
            "minLength": 1,
            "type": "string"
          },
          "apellidosCliente": {
            "minLength": 1,
            "type": "string"
          },
          "direccionEnvio": {
            "minLength": 1,
            "type": "string",
            "format": "string"
          },
          "fechaAlquiler": {
            "type": "string",
            "format": "date"
          },
          "precioTotal": {
            "type": "number",
            "format": "currency",
            "readOnly": true
          },
          "periodo": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "alquilerItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AlquilarItemDTO"
