@page "/alquiler/detailalquiler"

@using AppForSEII2526.Web.API
@using Microsoft.AspNetCore.Authorization
@inject AppForHerramientasAPIClient apiclient
@inject ILogger<SelectHerramientaForAlquiler> logger

<h3>DetailAlquiler</h3>

@*attribute [Authorize]*@



<div class="container-fluid mb-3">
    <div class="row">
        <div class="col">
            <div class="input-group">
                <span class="input-group-text" id="basic-addon1">Id</span>
                <input type="text" id="inputId" @bind="alquilerID" class="form-control" placeholder="Id del alquiler" aria-label="Id" aria-describedby="basic-addon1">
            </div>
        </div>
        <div class="col">
            <button type="button" class="btn btn-primary" @onclick="SearchAlquiler" id="searchOfertas">Search Alquiler</button>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(errors))
{
    <div class="alert alert-warning" role="alert">
        @errors
    </div>
}

@if (alquiler != null)
{
    <div class="container-fluid">
        <table class="table table-borderless table-sm">
            <tr>
                <th>ID Alquiler</th>
                <td id="IdAlquiler">@alquiler.Id</td>
            </tr>
            <tr>
                <th>Nombre del cliente</th>
                <td id="NombreCliente">@alquiler.NombreCliente</td>
            </tr>
            <tr>
                <th>Apellidos del cliente</th>
                <td id="FechaFinal">@alquiler.ApellidosCliente</td>
            </tr>
            <tr>
                <th>Dirección de envío</th>
                <td id="FechaOferta">@alquiler.DireccionEnvio</td>
            </tr>
            <tr>
                <th>Fecha Alquiler</th>
                <td id="MetodoPago">@alquiler.FechaAlquiler.ToString("dd/MM/yyyy")</td>
            </tr>
            <tr>
                <th>Periodo</th>
                <td id="TipoDirigida">@alquiler.Periodo días</td>
            </tr>
            <tr>
                <th>Items en el Alquiler</th>
                <td id="ItemsCount">@alquiler.AlquilerItems.Count</td>
            </tr>
        </table>

        <h4>Herramientas alquiladas</h4>

        <table class="table table-striped table-hover" id="HerramientasAlquiladas">
            <thead class="table-light">
                <tr>
                    <th scope="col">ID</th>
                    <th scope="col">Herramienta</th>
                    <th scope="col">Material</th>
                    <th scope="col">Fabricante</th>
                    <th scope="col">Precio</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in alquiler.AlquilerItems)
                {
                    <tr id="AlquilarItem_@item.HerramientaId">
                        <td>@item.HerramientaId</td>
                        <td>@item.NombreHerramienta</td>
                        <td>@item.Material</td>
                        <td>@item.Cantidad</td>
                        <td>@item.Precio.ToString("0.00") €</td>
                    </tr>
                }
            </tbody>

            <tfoot class="table-light">
                <tr>
                    <th scope="row" colspan="4" class="text-end">Precio Total del alquiler</th>
                    <td id="TotalPrice">
                        @alquiler.PrecioTotal.ToString("0.00") €
                    </td>
                </tr>
            </tfoot>
        </table>
    </div>
}

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public int alquilerID { get; set; }
    private AlquilerDetailDTO alquiler;
    private bool hideErrors { get { return errors.Length == 0; } }
    private string errors = "";

    
    [CascadingParameter]
    private Task<AuthenticationState>? authenticationState { get; set; }

    public async void SearchAlquiler()
    {
        try
        {
            alquiler = await apiclient.GetAlquilerPorIdAsync(alquilerID);
            errors = "";
        }
        catch (ApiException ex)
        {
            logger.LogError($"{DateTime.Now} Error: {ex}");
            errors = "ID no válido";
        }
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        @*string userName = "";
        if (authenticationState is not null) {
            var authState = await authenticationState;
            var user = authState?.User;

            if (user is not null) {
                if (user.Identity is not null && user.Identity.IsAuthenticated && user.IsInRole("User")) {
                    userName = user.Identity.Name;
                }
            }
        }*@

        if (alquilerID > 0)
        {
            SearchAlquiler();
        }
        else
        {
            errors = "Por favor, introduce un ID para buscar.";
        }
    }
}