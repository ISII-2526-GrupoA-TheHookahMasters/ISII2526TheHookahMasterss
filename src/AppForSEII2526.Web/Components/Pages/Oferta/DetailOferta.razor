@page "/oferta/detailoferta"

@using AppForSEII2526.Web.API
@using Microsoft.AspNetCore.Authorization
@inject AppForHerramientasAPIClient apiclient
@inject ILogger<SelectHerramientasForOferta> logger

<h3>DetailOferta</h3>

@*@attribute [Authorize]*@

    @if (!string.IsNullOrEmpty(errors))
    {
        <div class="alert alert-warning" role="alert">
            @errors
        </div>
    }

    @if (oferta != null)
    {
        <div class="container-fluid">
            <table class="table table-borderless table-sm">
                <tr>
                    <th>ID Oferta</th>
                    <td id="IdOferta">@oferta.Id</td>
                </tr>
                <tr>
                    <th>Fecha de Inicio</th>
                    <td id="FechaInicio">@oferta.FechaInicio.ToString("dd/MM/yyyy")</td>
                </tr>
                <tr>
                    <th>Fecha Final</th>
                    <td id="FechaFinal">@oferta.FechaFinal.ToString("dd/MM/yyyy")</td>
                </tr>
                <tr>
                    <th>Fecha de la Oferta</th>
                    <td id="FechaOferta">@oferta.FechaOferta.ToString("dd/MM/yyyy")</td>
                </tr>
                <tr>
                    <th>Método de Pago</th>
                    <td id="MetodoPago">@oferta.TipoMetodoPago</td>
                </tr>
                <tr>
                    <th>Dirigida a</th>
                    <td id="TipoDirigida">@oferta.TipoDirigidaOferta</td>
                </tr>
                <tr>
                    <th>Items en la Oferta</th>
                    <td id="ItemsCount">@oferta.OfertaItems.Count</td>
                </tr>
            </table>

            <h4>Herramientas ofertadas</h4>

            <table class="table table-striped table-hover" id="HerramientasOfertadas">
                <thead class="table-light">
                    <tr>
                        <th scope="col">ID</th>
                        <th scope="col">Herramienta</th>
                        <th scope="col">Material</th>
                        <th scope="col">Fabricante</th>
                        <th scope="col">Precio</th>
                        <th scope="col">Porcentaje</th>
                        <th scope="col">Precio Final (€)</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in oferta.OfertaItems)
                    {
                        <tr id="OfertaItem_@item.HerramientaId">
                            <td>@item.HerramientaId</td>
                            <td>@item.NombreHerramienta</td>
                            <td>@item.Material</td>
                            <td>@item.Fabricante</td>
                            <td>@item.Precio.ToString("0.00") €</td>
                            <td>@item.Porcentaje %</td>
                            <td>@item.PrecioFinal.ToString("0.00") €</td>
                        </tr>
                    }
                </tbody>

                <tfoot class="table-light">
                    <tr>
                        <th scope="row" colspan="6" class="text-end">Precio Total de la Oferta</th>
                        <td id="TotalPrice">
                            @CalcularPrecioFinal(oferta).ToString("0.00") €
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
}

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public int ofertaID { get; set; }
    private OfertaDetailDTO oferta;
    private bool hideErrors { get { return errors.Length == 0; } }
    private string errors = "";

    protected float CalcularPrecioFinal(OfertaDetailDTO oferta)
    {
        float total = 0;

        if (oferta?.OfertaItems != null)
        {
            foreach (var item in oferta.OfertaItems)
            {
                total += (float)item.PrecioFinal;
            }
        }
        return total;
    }

    [CascadingParameter]
    private Task<AuthenticationState>? authenticationState { get; set; }

    public async void SearchOfertas()
    {
        try
        {
            oferta = await apiclient.GetOfertasPorIdAsync(ofertaID);
            errors = "";
        }
        catch (ApiException ex)
        {
            logger.LogError($"{DateTime.Now} Error: {ex}");
            errors = "ID no válido";
        }
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync() {
        @*string userName = "";
        if (authenticationState is not null) {
            var authState = await authenticationState;
            var user = authState?.User;

            if (user is not null) {
                if (user.Identity is not null && user.Identity.IsAuthenticated && user.IsInRole("User")) {
                    userName = user.Identity.Name;
                }
            }
        }*@

        try
        {
            oferta = await apiclient.GetOfertasPorIdAsync(ofertaID);
            errors = "";
        }
        catch (ApiException ex)
        {
            logger.LogError($"{DateTime.Now} Error: {ex}");
            errors = "ID no válido";
            oferta = null;
        }
        if (oferta == null) 
        {
            errors = $"Error! There is not a oferta with id={ofertaID}";
        }

    }
}
