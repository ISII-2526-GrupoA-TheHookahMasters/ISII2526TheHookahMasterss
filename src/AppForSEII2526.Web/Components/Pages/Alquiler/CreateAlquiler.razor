@page "/alquiler/createalquiler"

@inject NavigationManager navigation
@using AppForSEII2526.Web.API
@inject AppForHerramientasAPIClient apiclient
@inject ILogger<CreateAlquiler> logger
@inject AlquilerStateContainer AlquilerState
@using AppForSEII2526.Web.Components.Shared
@using Microsoft.AspNetCore.Authorization



<h3>Create Alquiler</h3>

<EditForm Model="alquiler" OnValidSubmit="OpenDialog">
    <div class="row">
        <DataAnnotationsValidator />
        <ValidationSummary class="row alert alert-danger" />
    </div>
    <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
        <p id="ErrorsShown">Errors: @messageError</p>
    </div>
    <div class="row g-3">
        <div class="col-12">
            <div class="form-floating">
                <InputText @bind-Value="alquiler.NombreCliente" class="form-control" id="Nombre" />
                <label for="Nombre">Nombre </label>
            </div>
        </div>
        <div class="col-12">
            <div class="form-floating">
                <InputText @bind-Value="alquiler.ApellidosCliente" class="form-control" id="Apellido" />
                <label for="Apellido">Apellido </label>
            </div>
        </div>
        <div class="col-12">
            <div class="form-floating">
                <InputDate @bind-Value="alquiler.FechaInicio" class="form-control" id="FechaInicio" />
                <label for="FechaInicio">Fecha de Inicio</label>
            </div>
        </div>
        <div class="col-12">
            <div class="form-floating">
                <InputDate @bind-Value="alquiler.FechaFin" class="form-control" id="FechaFinal" />
                <label for="FechaFinal">Fecha Final </label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating">
                <InputText @bind-Value="alquiler.DireccionEnvio" class="form-control" id="DirecciónEnvio" />
                <label for="DirecciónEnvio">DirecciónEnvio</label>
            </div>
        </div>
        <div class="col-12">
            <div class="form-floating">
                @*a dropdown for selecting the payment method*@
                <InputSelect class="form-select" @bind-Value="@alquiler.TipoMetodoPago" id="MetodoPago">
                    <option value="@TiposMetodoPago.TarjetaCredito" default> TarjetaCredito</option>
                    <option value="@TiposMetodoPago.PayPal"> PayPal</option>
                    <option value="@TiposMetodoPago.Efectivo"> Efectivo</option>
                </InputSelect>
                <label for="MetodoPago">MetodoPago</label>
            </div>
        </div>
        <div class="col-12">
            <div class="form-floating mb-5">
                @*this button will be used to ask the user if he want to proceed to rent the movies*@
                <button class="btn btn-primary" type="submit" id="Submit">
                    Alquilar herramientas
                </button>
            </div>
        </div>
    </div>

    <h4>Alquiler detail</h4>
    <p><b>Date from:</b> @alquiler.FechaInicio.ToString("dd/MM/yyyy") <b>to:</b> @alquiler.FechaFin.ToString("dd/MM/yyyy")</p>
    <p>
        <b>Total price:</b> @PrecioTotal €
    </p>
    <button class="btn btn-outline-primary" type="submit" @onclick="ModifyAlquilerItems" id="ModifyHerramientas">
        Modify herramientas
    </button>
    <div class="mh-100 table-responsive">
        <table class="table table-condensed table-hover" id="TableOfAlquilerItems">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Material</th>
                    <th>Precio</th>
                    <th>Cantidad</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var herramienta in alquiler.AlquilerItems)
                {
                    <tr id="HerramientaData_@herramienta.HerramientaId">
                        <td>@herramienta.NombreHerramienta</td>
                        <td>@herramienta.Material</td>
                        <td>@herramienta.Precio</td>
                    <td><InputNumber @bind-Value="herramienta.Cantidad" class="form-control" id="@($"cantidad{herramienta.HerramientaId}")" /></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</EditForm>

@if (DialogIsOpen)
{
    <Dialog Caption="Alquilar Herramientas"
    Message="¿Quieres alquilar las herramientas seleccionadas?"
    OnClose="@OnDialogClose"
    Type=Dialog.Category.SaveNot>
    </Dialog>
}

@code {

    private string messageError = "";
    private bool hideErrors { get { return messageError.Length == 0; } }

    private bool DialogIsOpen;

    private float PrecioTotal
    {
        get
        {
            int days = (alquiler.FechaFin.DateTime - alquiler.FechaInicio.DateTime).Days;
            float price = (float) alquiler.AlquilerItems.Sum(ri => ri.Precio * days);
            return price;
        }
    }
    private void ModifyAlquilerItems()
    {
        navigation.NavigateTo("/alquiler/selectherramientasforalquiler");
    }

    private AlquilerForCreateDTO alquiler => AlquilerState.Alquiler;

    private void OpenDialog()
    {
        DialogIsOpen = true;
    }

    private async Task OnDialogClose(bool isOk)
    {
        DialogIsOpen = false;
        if (isOk)
        {
            if (alquiler.AlquilerItems.Count > 0)
            {
                try
                {
                    var alquilo = await apiclient.CreateAlquilerAsync(alquiler);
                    AlquilerState.AlquilerProcessed();
                    navigation.NavigateTo($"/alquiler/detailalquiler/?AlquilerID={alquilo.Id}");
                }
                catch (ApiException<ValidationProblemDetails> apiexceptionvalidation)
                {

                    if (apiexceptionvalidation.Result.Errors.Values != null)
                    {
                        messageError = "";
                        foreach (var errors in apiexceptionvalidation.Result.Errors.Values)
                            //https://learn.microsoft.com/en-us/dotnet/api/system.string.join?view=net-7.0
                            messageError = string.Join("(*) ", messageError, string.Join(" (*) ", errors));
                    }
                }
                catch (ApiException apiexception)
                {
                    messageError = "Error while processing your request, please try again later!";

                }

            }

        }
    }
