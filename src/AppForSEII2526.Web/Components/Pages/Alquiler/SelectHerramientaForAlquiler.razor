@page "/alquiler/selectalquileroferta"

@using Microsoft.AspNetCore.Authorization
@using AppForSEII2526.Web.API
@inject AppForHerramientasAPIClient apiclient
@inject ILogger<SelectHerramientaForAlquiler> logger
@inject AlquilerStateContainer AlquilerState
@inject NavigationManager navigation

@*@attribute [Authorize]*@ 




<h3>SelectHerramientaForAlquiler</h3>


<div class="container-fluid">
    <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
        <p id="ErrorsShown">Errors: @errors</p>
    </div>
    <div class="row">
        <div class="col-8">
            <div class="row">

                <div class="col">
                    <div class="input-group mb-3">
                        <span class="input-group-text" id="basic-addon1">Title</span>
                        <input type="text" id="inputNombre" @bind=herramientaNombre class="form-control" placeholder="Nombre" aria-label="Nombre" aria-describedby="basic-addon1">
                    </div>
                </div>
                <div class="col">
                    <div class="input-group mb-3">
                        <span class="input-group-text" id="basic-addon1">Genre</span>
                        <input type="text" id="inputMaterial" @bind=herramientaMaterial class="form-control" placeholder="Material" aria-label="Material" aria-describedby="basic-addon1">
                    </div>
                </div>

                <div class="col">
                    <button type="button" class="btn btn-primary" @onclick=@SearchHerramientas id="SearchHerramientas">Search Herramientas</button>
                </div>

            </div>
            <div class="row">
                @if (herramientas == null)
                {
                    <p>Loading herramientas....</p>
                }
                else
                {
                    <div class="mh-100 table-responsive">
                        <table class="table table-condensed table-hover" id="TableOfHerramientas">
                            <thead>
                                <tr>
                                    <th>Id</th>
                                    <th>Nombre</th>
                                    <th>Material</th>
                                    <th>Precio</th>
                                    <th>Fabricante</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var herramienta in herramientas)
                                {
                                    <tr id="HerramientaData_@herramienta.Id">
                                        <td>@herramienta.Id</td>
                                        <td>@herramienta.Nombre</td>
                                        <td>@herramienta.Material</td>
                                        <td>@herramienta.Precio</td>
                                        <td>@herramienta.Fabricante</td>
                                        <td>
                                            <button class="btn btn-outline-secondary" id="herramientaToAlquiler_@herramienta.Nombre" @onclick="@(() => AddHerramienta(herramienta))">Añadir</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                }
            </div>
        </div>
        <div class="col-2" hidden="@hideRentingCart">
            <div class="row">
                <h3>Shopping Cart</h3>
            </div>
            @foreach (AlquilarItemDTO herramienta in alquiler.AlquilerItems)
            {
                <div class="row">
                    <button type="button" class="btn btn-light" id="removeHerramienta_@herramienta.NombreHerramienta" @onclick="@(() => RemoveAlquilerItem(herramienta))">x @herramienta.NombreHerramienta - @herramienta.Precio€</button>
                </div>
            }
            <div class="row">
                <button type="button" class="btn btn-primary" id="alquilerHerramientaButton" @onclick=@AlquilarHerramientas>Alquilar herramienta</button>
            </div>
        </div>

    </div>

</div>




@code {
    private bool hideRentingCart { get { return alquiler.AlquilerItems.Count == 0; } }


    private ICollection<HerramientasParaAlquilarDTO> herramientas;
    private bool hideErrors { get { return errors.Length == 0; } }
    private string errors = "";
    private string herramientaNombre { get; set; }
    private string herramientaMaterial { get; set; }



    private AlquilerForCreateDTO alquiler => AlquilerState.Alquiler;

    private bool hiddenAlquilerCart = true;

    private void AddHerramienta(HerramientasParaAlquilarDTO herramientas)
    {
        AlquilerState.AddHerramientaToAlquiler(herramientas);
    }

    private void RemoveAlquilerItem(AlquilarItemDTO item)
    {
        AlquilerState.RemoveAlquilerItemToAlquiler(item);
        if (alquiler.AlquilerItems.Count == 0) hiddenAlquilerCart = true;
    }


    public async void SearchHerramientas()
    {
        try
        {
            herramientas = await apiclient.GetHerramientasNombreMaterialAsync(herramientaNombre, herramientaMaterial);
            errors = "";
        }
        catch (ApiException ex)
        {
            logger.LogError($"{DateTime.Now} Error: {ex}");
            errors = "Error while connecting to the system";
        }
        StateHasChanged();
    }

    protected override Task OnInitializedAsync()
    {
        SearchHerramientas();
        return base.OnInitializedAsync();
    }

    private void AlquilarHerramientas()
    {
        navigation.NavigateTo("/alquiler/createalquiler");
    }


}
