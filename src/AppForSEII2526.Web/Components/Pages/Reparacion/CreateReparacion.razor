@page "/reparaciones/createreparacion"

@inject NavigationManager navigation
@using AppForSEII2526.Web.Components.Shared
@using AppForSEII2526.Web.API
@inject AppForHerramientasAPIClient apiclient
@inject ILogger<CreateReparacion> logger
@inject ReparacionStateContainer reparacionState

<h3>Create Reparacion</h3>

<EditForm Model="reparacion" OnValidSubmit="OpenDialog">
    
    <div class="row">
        <DataAnnotationsValidator />
        <ValidationSummary />
    </div>
    

    <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
        <p id="ErrorsShown">Errors: @messageError</p>
    </div>

    <div class="row g-3">
        <div class="col-12">
            <div class="form-floating mb-3">
                <InputText @bind-Value="reparacion.NombreCliente" class="form-control" id="inputNombre" />
                <label for="Nombre">Nombre </label>
            </div>
        </div>
        <div class="col-12">
            <div class="form-floating mb-3">
                <InputText @bind-Value="reparacion.ApellidosCliente" class="form-control" id="inputApellido" />
                <label for="Apellidos">Apellidos </label>
            </div>
        </div>
        <div class="col-12">
            <div class="form-floating mb-3">
                <InputDate @bind-Value="reparacion.FechaEntrega" class="form-control" id="inputFechaEntrega" />
                <label for="FechaEntrega">Fecha de Entrega</label>
            </div>
        </div>
        <div class="col-12">
            <div class="form-floating">
                <InputSelect class="form-select" @bind-Value="@reparacion.TipoMetodoPago" id="TipoMetodoPago">
                    <option value="@TiposMetodoPago.TarjetaCredito" default> Tarjeta de Crédito</option>
                    <option value="@TiposMetodoPago.PayPal"> PayPal</option>
                    <option value="@TiposMetodoPago.Efectivo"> Efectivo</option>
                </InputSelect>
                <label for="TipoMetodoPago">Método de Pago</label>
            </div>
        </div>

       
        <div class="col-12">
            <div class="form-floating">
                <button class="btn btn-primary" type="submit" id="crearReparacionButton" disabled="@(!PuedeReparar)">
                    Repara tus herramientas
                </button>
            </div>
        </div>
    </div>


    
    <h4>Detalle de la Reparacion</h4>
    <p><b>Fecha de Entrega:</b> @reparacion.FechaEntrega.ToString("dd/MM/yyyy")</p>
    <p>
        <b>Total price:</b> @PrecioTotal €
        <button class="btn btn-outline-primary" type="button" @onclick="ModifyReparacionItems" id="ModifyHerramientas">
            Modificar Reparacion
        </button>
    </p>

    <div class="mh-100 table-responsive">
        <table class="table table-condensed table-hover" id="TableOfReparacionItems">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Tiempo Reparacion</th>
                    <th>Precio</th>
                    <th>Cantidad <span class="text-danger">*</span></th>
                    <th>Descripcion (opcional)</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in reparacion.ReparacionItems)
                {
                    <tr id="HerramientaData_@item.NombreHerramienta">
                        <td>@item.NombreHerramienta</td>
                        <td>@item.TiempoReparacion </td>
                        <td>@item.Precio</td>
                        <td><InputNumber @bind-Value="item.Cantidad" class="form-control" id="@($"Cantidad_{item.HerramientaId}")" /></td>
                        <td><InputText @bind-Value="item.Descripcion" class="form-control" id="@($"Descripcion_{item.HerramientaId}")" /></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>


</EditForm>

@if (DialogIsOpen)
{
    <Dialog Caption="Reparar herramientas"
    Message="Quieres reparar las siguientes herramientas?"
    OnClose="@OnDialogClose"
    Type=Dialog.Category.SaveNot>
    </Dialog>
}

@code{

    private string messageError = "";
    private bool hideErrors { get { return messageError.Length == 0; } }
    private bool DialogIsOpen;
    private ReparacionForCreateDTO reparacion => reparacionState.Reparacion;

    private void ModifyReparacionItems()
    {
        navigation.NavigateTo("/reparar/selectherramientasforreparar");
    }

    private float PrecioTotal
    {
        get
        {
            float total = 0;
            foreach (var item in reparacion.ReparacionItems)
            {
                total += (float) item.Precio * item.Cantidad;
            }
            return total;
        }
    }

    private void OpenDialog()
    {
        DialogIsOpen = true;
    }

    private async Task OnDialogClose(bool isOk)
    {
        DialogIsOpen = false;
        if (isOk)
        {
            if (reparacion.ReparacionItems.Count > 0)
            {
                try
                {
                    var reparado = await apiclient.CreateReparacionAsync(reparacion);
                    reparacionState.ReparacionProcessed();
                    navigation.NavigateTo($"/reparacion/detailreparacion/?ReparacionID={reparado.Id}");
                }
                catch (ApiException<ValidationProblemDetails> apiexceptionvalidation)
                {

                    if (apiexceptionvalidation.Result.Errors.Values != null)
                    {
                        messageError = "";
                        foreach (var errors in apiexceptionvalidation.Result.Errors.Values)
                            messageError = string.Join("(*) ", messageError, string.Join(" (*) ", errors));
                    }
                }

            }
        }
    }

    [CascadingParameter]
    private Task<AuthenticationState>? authenticationState { get; set; }

    private bool PuedeReparar =>
    reparacion.ReparacionItems != null &&
    reparacion.ReparacionItems.Count > 0 &&
    reparacion.ReparacionItems.All(i => i.Cantidad >= 1);
}